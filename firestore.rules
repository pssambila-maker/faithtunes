rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin UIDs allowlist
    function isAdmin() {
      return request.auth != null &&
             request.auth.uid in ['ahyesXEL5reyWMKwyanOQ853pey2'];
    }

    // Studies collection - users can only access their own studies
    match /studies/{studyId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll([
                      'userId', 'reference', 'translation',
                      'createdAt', 'modelName', 'modelVersion',
                      'analysis', 'userNotes', 'tags'
                    ]);
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.reference == resource.data.reference
                    && request.resource.data.translation == resource.data.translation
                    && request.resource.data.analysis == resource.data.analysis;
      allow delete: if isOwner(resource.data.userId);
    }

    // Rate limiting collection
    match /rateLimits/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ===== FAITHTUNES MUSIC APP =====

    // Songs collection
    match /songs/{songId} {
      // Any authenticated user can read songs
      allow read: if isAuthenticated();
      // Only admins can create, update, delete
      allow create, update, delete: if isAdmin();
    }

    // User favorites subcollection
    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isOwner(userId);
    }

    // User profile for FaithTunes
    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
    }
  }
}
